# OpenEMR MCP Server — Environment Variables
# Copy this file to .env and fill in your values.
# All variables are optional unless noted.

# ---------------------------------------------------------------------------
# Data Source
# ---------------------------------------------------------------------------
# Controls where patient/clinical data comes from.
#   mock  (default) — built-in curated demo data, no network required
#   db              — direct MySQL connection to OpenEMR database
#   api             — OpenEMR FHIR R4 REST API (recommended for production)
OPENEMR_DATA_SOURCE=mock

# ---------------------------------------------------------------------------
# Database Mode (OPENEMR_DATA_SOURCE=db)
# ---------------------------------------------------------------------------
OPENEMR_DB_HOST=localhost
OPENEMR_DB_PORT=3306
OPENEMR_DB_USER=openemr
OPENEMR_DB_PASS=openemr
OPENEMR_DB_NAME=openemr

# ---------------------------------------------------------------------------
# API / FHIR Mode (OPENEMR_DATA_SOURCE=api)
# ---------------------------------------------------------------------------
# Base URL of your OpenEMR installation's API endpoint
OPENEMR_API_BASE_URL=https://your-openemr.example.com/apis/default

# OAuth2 credentials for OpenEMR's built-in OAuth2 server
OPENEMR_OAUTH_HOST=https://your-openemr.example.com
OPENEMR_OAUTH_CLIENT_ID=your_client_id
OPENEMR_OAUTH_CLIENT_SECRET=your_client_secret
OPENEMR_OAUTH_USER=admin
OPENEMR_OAUTH_PASS=your_password
# Scope requested from OpenEMR OAuth2
OPENEMR_OAUTH_SCOPE=openid fhirUser offline_access user/Patient.read user/Medication.read user/Appointment.read user/Observation.read

# ---------------------------------------------------------------------------
# Drug Interactions
# ---------------------------------------------------------------------------
# Controls the drug interaction checker.
#   mock    (default) — 10 built-in drug pairs, always works, no network
#   rxnorm            — NLM RxNorm Interaction API (free, no key needed)
DRUG_INTERACTION_SOURCE=mock

# ---------------------------------------------------------------------------
# Symptom Checker
# ---------------------------------------------------------------------------
# Controls symptom lookup data source.
#   mock        (default) — curated local dataset, instant, no network
#   infermedica             — Infermedica Symptom Checker API
#                            Free tier: 100 calls/day
#                            Register at: https://developer.infermedica.com/
SYMPTOM_SOURCE=mock

# Infermedica API credentials (required when SYMPTOM_SOURCE=infermedica)
INFERMEDICA_APP_ID=
INFERMEDICA_APP_KEY=

# ---------------------------------------------------------------------------
# OpenFDA
# ---------------------------------------------------------------------------
# Controls FDA adverse events and drug label lookups.
#   mock  (default) — built-in FDA mock data for 6 common drugs
#   live            — live OpenFDA API (free, higher rate limits with key)
OPENFDA_SOURCE=mock

# OpenFDA API key (optional; increases rate limits from 40 to 240 req/min)
# Register at: https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=
